{
  "name": "signalk-synthetic-values",
  "version": "0.1.0",
  "description": "Combine redundant sensors on one Signal K path into a robust median or outlier-rejected value",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "signalk",
    "redundancy",
    "sensor-fusion",
    "median",
    "outlier"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Synthetic Values",
    "appIcon": "assets/appicon.png",
    "screenshots": []
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "type": "module",
  "files": ["dist", "assets", "README.md", "CHANGELOG.md", "LICENSE"],
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com",
    "url": "https://github.com/NearlCrews"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-synthetic-values.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-synthetic-values/issues"
  },
  "homepage": "https://github.com/NearlCrews/signalk-synthetic-values#readme",
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/nearlcrews"
  },
  "engines": {
    "node": ">=20.18"
  },
  "peerDependencies": {
    "@signalk/server-api": ">=2.24.0"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:types": "tsc --noEmit false --declaration --emitDeclarationOnly --outDir dist",
    "build:bundle": "node esbuild.config.js",
    "build": "npm run clean && npm run build:types && npm run build:bundle",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "validate": "npm run type-check && npm run lint && npm run test",
    "prepublishOnly": "npm run validate && npm run build",
    "hooks": "husky",
    "security-audit": "npm audit --audit-level=moderate",
    "dev": "tsx watch src/index.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ],
    "*.{json,md}": [
      "biome format --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@signalk/server-api": "^2.28.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
