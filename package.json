{
  "name": "signalk-synthetic-values",
  "version": "0.1.0",
  "description": "Combine redundant sensors on one Signal K path into a robust median or outlier-rejected value",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-utility",
    "signalk",
    "redundancy",
    "sensor-fusion",
    "median",
    "outlier"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Synthetic Values",
    "appIcon": "./assets/icons/icon-192.png",
    "screenshots": [
      "./assets/screenshots/01-config-panel.png",
      "./assets/screenshots/02-not-recommended.png",
      "./assets/screenshots/03-tune.png",
      "./assets/screenshots/04-data-browser.png"
    ],
    "recommends": [
      "signalk-nmea2000-emitter-cannon"
    ]
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist",
    "public",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com",
    "url": "https://github.com/NearlCrews"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-synthetic-values.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-synthetic-values/issues"
  },
  "homepage": "https://github.com/NearlCrews/signalk-synthetic-values#readme",
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/nearlcrews"
  },
  "engines": {
    "node": ">=20.18"
  },
  "peerDependencies": {
    "@signalk/server-api": ">=2.24.0"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:types": "tsc --noEmit false --declaration --emitDeclarationOnly --outDir dist",
    "build:bundle": "node esbuild.config.js",
    "build:panel": "webpack",
    "build": "npm run clean && npm run build:types && npm run build:bundle && npm run build:panel",
    "type-check": "tsc --noEmit && npm run type-check:panel",
    "type-check:panel": "tsc -p tsconfig.panel.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "validate": "npm run type-check && npm run lint && npm run test",
    "prepublishOnly": "npm run validate && npm run build",
    "hooks": "husky",
    "security-audit": "npm audit --audit-level=moderate",
    "dev": "tsx watch src/index.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ],
    "*.{json,md}": [
      "biome format --write"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@biomejs/biome": "^2.5.1",
    "@signalk/server-api": "^2.28.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-loader": "^10.1.1",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "react": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
